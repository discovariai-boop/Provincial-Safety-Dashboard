rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Videos - uploaded by citizens, accessible to authorized personnel
    match /videos/{allPaths=**} {
      allow read: if request.auth != null && 
        request.auth.token.role in ['premier', 'minister', 'director', 'commander', 'chief', 'admin', 'analyst'];
      allow create: if request.auth != null; // Citizens can upload
      allow delete: if request.auth != null && 
        (resource.metadata.uploadedBy == request.auth.uid || 
         request.auth.token.role in ['premier', 'admin']);
    }

    // Public assets - readable by anyone
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null && 
        request.auth.token.role in ['premier', 'admin'];
    }

    // Department-specific storage
    match /departments/{department}/{allPaths=**} {
      allow read, write: if request.auth != null && 
        (request.auth.token.department == department || 
         request.auth.token.role in ['premier', 'admin', 'national_executive']);
    }

    // Deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
